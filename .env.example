# Samantha env vars — set these in Vercel.
# Dashboard: https://vercel.com/carbcleantruckcheckapp/gillybelichick/settings/environment-variables
# Apply each to Production + Preview + Development unless noted.

# ── Required: Claude / Anthropic ──
# Samantha accepts the key under any of these names (first non-empty wins).
# Pick ONE. No need to rename if the key is already set as SAMANTHA or CLAUDE.
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_API_KEY=
# SAMANTHA_API_KEY=
# SAMANTHA=
# CLAUDE=
# ANTHROPIC_KEY=

# ── Required for Gmail + Calendar ──
# Walk through setup at: https://gillybelichick.vercel.app/api/samantha/status?auth
# That page guides the Google Cloud Console steps, returns a refresh token,
# and links back to Vercel env var settings for each paste.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Optional: extra tools ──
GOOGLE_MAPS_API_KEY=
FMCSA_API_KEY=
ELEVENLABS_API_KEY=

# ── Optional: Cloudflare D1 (blog + project board) ──
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_D1_TOKEN=

# ── Optional: one-tap redeploy from the status page ──
# Create at Vercel → Settings → Git → Deploy Hooks (branch: main), copy the URL,
# paste here. Unlocks the "Redeploy production now" button on
# /api/samantha/status.
VERCEL_DEPLOY_HOOK_URL=
